FROM python:3.10-slim-bullseye

LABEL maintainer="foo@bar.com"
ARG TZ='Asia/Shanghai'

ARG CHATGPT_ON_WECHAT_VER
# Set to "false" to skip Playwright/Chromium and produce a smaller image
ARG INSTALL_BROWSER=true
# Set to "true" to use China mirrors for apt / pip / playwright (faster in CN)
ARG USE_CN_MIRROR=false
ARG PLAYWRIGHT_DOWNLOAD_HOST=https://registry.npmmirror.com/-/binary/playwright

ENV PLAYWRIGHT_BROWSERS_PATH=/app/ms-playwright
ENV PLAYWRIGHT_DOWNLOAD_HOST=${PLAYWRIGHT_DOWNLOAD_HOST}
ENV BUILD_PREFIX=/app
ENV DEBIAN_FRONTEND=noninteractive

# Optionally switch apt and pip to China mirrors
RUN if [ "$USE_CN_MIRROR" = "true" ]; then \
        sed -i 's/deb.debian.org/mirrors.tuna.tsinghua.edu.cn/g' /etc/apt/sources.list; \
        pip config set global.index-url https://pypi.tuna.tsinghua.edu.cn/simple/; \
    fi

ADD . ${BUILD_PREFIX}

# All heavy installs + user creation in ONE layer to avoid chown duplication
RUN set -eux; \
    apt-get update; \
    apt-get install -y --no-install-recommends bash ffmpeg espeak passwd ca-certificates; \
    (apt-get install -y --no-install-recommends libavcodec-extra \
        || apt-get install -y --no-install-recommends libavcodec-extra58 \
        || true); \
    rm -rf /var/lib/apt/lists/*

RUN set -eux; \
    cd ${BUILD_PREFIX}; \
    if [ -f config-template.json ]; then cp config-template.json config.json; else printf '{}' > config.json; fi; \
    /usr/local/bin/python -m pip install --no-cache --upgrade pip setuptools wheel

RUN set -eux; \
    cd ${BUILD_PREFIX}; \
    python -m pip install --no-cache -r requirements.txt

RUN set -eux; \
    cd ${BUILD_PREFIX}; \
    python -m pip install --no-cache -r requirements-optional.txt

RUN set -eux; \
    cd ${BUILD_PREFIX}; \
    python -m pip install --no-cache -e .

RUN set -eux; \
    if [ "$INSTALL_BROWSER" = "true" ]; then \
        apt-get update; \
        (apt-get install -y --no-install-recommends fonts-wqy-zenhei || true); \
        python -m pip install --no-cache "playwright==1.52.0"; \
        python -m playwright install-deps chromium; \
        mkdir -p /app/ms-playwright; \
        python -m playwright install chromium; \
        rm -rf /var/lib/apt/lists/*; \
    fi

RUN set -eux; \
    mkdir -p /home/agent/cow; \
    groupadd -r agent; \
    useradd -r -g agent -s /bin/bash -d /home/agent agent; \
    chown -R agent:agent /home/agent ${BUILD_PREFIX} /usr/local/lib

WORKDIR ${BUILD_PREFIX}

ADD docker/entrypoint.sh /entrypoint.sh

RUN chmod +x /entrypoint.sh \
    && chown agent:agent /entrypoint.sh

ENTRYPOINT ["/entrypoint.sh"]
